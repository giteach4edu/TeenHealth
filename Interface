<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TeenHealth Analytics System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #dbe8ef;
      --text: #111111;
      --white: #ffffff;
      --primary: #2f7fd8;
      --primary-dark: #205fa8;
      --shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
      --radius-lg: 22px;
      --radius-md: 16px;
    }

    body {
      font-family: "Be Vietnam Pro", sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    .page {
      width: 100%;
      max-width: 1400px;
      margin: 0 auto;
      padding: 26px 30px 40px;
    }

    .topbar {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 48px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .brand-logo {
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #9fe38c, #4da4dd 70%);
      box-shadow: var(--shadow);
      position: relative;
      flex-shrink: 0;
      overflow: hidden;
    }

    .brand-logo::before {
      content: "";
      position: absolute;
      inset: 10px;
      background: rgba(255, 255, 255, 0.85);
      border-radius: 50%;
    }

    .brand-logo::after {
      content: "🌿";
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      font-size: 26px;
      z-index: 1;
    }

    .brand-text h1 {
      font-size: 1.1rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.2px;
      line-height: 1.2;
      margin-bottom: 2px;
    }

    .brand-text p {
      font-size: 1rem;
      font-weight: 400;
      line-height: 1.35;
    }

    .nav-actions {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
    }

    .nav-btn,
    .cta-btn,
    .mini-btn,
    .feature-card {
      font-family: inherit;
      border: none;
      text-decoration: none;
      color: var(--text);
    }

    .nav-btn {
      min-width: 140px;
      padding: 14px 20px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.82);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.05);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .nav-btn:hover,
    .cta-btn:hover,
    .mini-btn:hover,
    .feature-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 22px rgba(0, 0, 0, 0.1);
    }

    .hero-title {
      font-size: clamp(2rem, 4.2vw, 3.8rem);
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 38px;
      max-width: 1200px;
    }

    .hero {
      display: grid;
      grid-template-columns: 1.05fr 1.35fr;
      align-items: center;
      gap: 24px;
    }

    .hero-visual {
      display: flex;
      align-items: flex-end;
      justify-content: flex-start;
      min-height: 430px;
      position: relative;
    }

    .doctor-wrap {
      position: relative;
      width: min(100%, 420px);
      height: 420px;
    }

    .bubble {
      position: absolute;
      border-radius: 50%;
      opacity: 0.9;
      background: #c7d9fb;
    }

    .bubble.one { width: 22px; height: 22px; left: 18px; top: 110px; }
    .bubble.two { width: 12px; height: 12px; left: 70px; top: 55px; }
    .bubble.three { width: 16px; height: 16px; right: 105px; top: 64px; }
    .bubble.four { width: 14px; height: 14px; left: 40px; bottom: 90px; }

    .phone-shape {
      position: absolute;
      left: 28px;
      bottom: 12px;
      width: 250px;
      height: 330px;
      border-radius: 36px;
      background: linear-gradient(180deg, #5e8ee8 0%, #3b6fd1 100%);
      box-shadow: var(--shadow);
    }

    .phone-shape::before {
      content: "";
      position: absolute;
      inset: 16px;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.18);
    }

    .phone-shape::after {
      content: "";
      position: absolute;
      width: 58px;
      height: 10px;
      background: rgba(255, 255, 255, 0.45);
      border-radius: 999px;
      top: 16px;
      left: 50%;
      transform: translateX(-50%);
    }

    .home-btn {
      position: absolute;
      width: 20px;
      height: 20px;
      border: 3px solid rgba(255, 255, 255, 0.9);
      border-radius: 50%;
      bottom: 10px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 2;
    }

    .icon-circle {
      position: absolute;
      border-radius: 50%;
      display: grid;
      place-items: center;
      color: #ffffff;
      font-size: 30px;
      font-weight: 700;
      box-shadow: var(--shadow);
    }

    .icon-circle.a { width: 78px; height: 78px; left: 18px; top: 128px; background: #b9d0fa; }
    .icon-circle.b { width: 74px; height: 74px; left: 88px; top: 12px; background: #4b7fe6; }
    .icon-circle.c { width: 72px; height: 72px; right: 82px; top: 110px; background: #6697ef; }
    .icon-circle.d { width: 74px; height: 74px; right: 24px; top: 178px; background: #4f88ea; }

    .doctor {
      position: absolute;
      left: 54px;
      bottom: 34px;
      width: 220px;
      height: 290px;
      z-index: 2;
    }

    .doctor .head {
      position: absolute;
      top: 10px;
      left: 72px;
      width: 74px;
      height: 78px;
      background: #ffd9c7;
      border-radius: 42px;
      z-index: 3;
    }

    .doctor .hair {
      position: absolute;
      top: 0;
      left: 54px;
      width: 112px;
      height: 102px;
      background: #16305f;
      border-radius: 58px 58px 42px 42px;
      z-index: 2;
    }

    .doctor .hair::after {
      content: "";
      position: absolute;
      left: 0;
      top: 30px;
      width: 30px;
      height: 80px;
      background: #16305f;
      border-radius: 40px;
      transform: rotate(8deg);
    }

    .doctor .body {
      position: absolute;
      top: 80px;
      left: 38px;
      width: 150px;
      height: 182px;
      background: #ffffff;
      border-radius: 28px 28px 20px 20px;
      z-index: 1;
      box-shadow: 0 6px 14px rgba(0,0,0,0.05);
    }

    .doctor .shirt {
      position: absolute;
      top: 86px;
      left: 83px;
      width: 58px;
      height: 128px;
      background: #d7e6ff;
      clip-path: polygon(0 0, 100% 0, 70% 100%, 30% 100%);
      z-index: 2;
    }

    .doctor .arm-left,
    .doctor .arm-right {
      position: absolute;
      background: #ffffff;
      border-radius: 20px;
      z-index: 1;
    }

    .doctor .arm-left {
      width: 38px;
      height: 120px;
      left: 26px;
      top: 108px;
      transform: rotate(16deg);
    }

    .doctor .arm-right {
      width: 40px;
      height: 118px;
      right: 8px;
      top: 94px;
      transform: rotate(-62deg);
    }

    .doctor .hand {
      position: absolute;
      width: 26px;
      height: 26px;
      background: #ffd9c7;
      border-radius: 50%;
      right: 6px;
      top: 142px;
      z-index: 2;
    }

    .doctor .clipboard {
      position: absolute;
      width: 58px;
      height: 82px;
      left: 48px;
      bottom: 22px;
      background: #4a7fdf;
      border-radius: 10px;
      transform: rotate(-22deg);
      z-index: 3;
      box-shadow: 0 5px 12px rgba(0,0,0,0.12);
    }

    .doctor .clipboard::before {
      content: "";
      position: absolute;
      width: 24px;
      height: 8px;
      background: #9ec1ff;
      border-radius: 6px;
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
    }

    .doctor .stethoscope {
      position: absolute;
      top: 100px;
      left: 68px;
      width: 80px;
      height: 90px;
      border: 4px solid #4f88ea;
      border-top: none;
      border-radius: 0 0 45px 45px;
      z-index: 3;
      opacity: 0.9;
    }

    .doctor .stethoscope::after {
      content: "";
      position: absolute;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: #4f88ea;
      bottom: -8px;
      left: 50%;
      transform: translateX(-50%);
    }

    .hero-actions {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 26px;
      min-height: 430px;
      padding-left: 10px;
    }

    .feature-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(180px, 220px));
      gap: 36px;
      align-items: start;
    }

    .feature-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      cursor: pointer;
      background: transparent;
    }

    .feature-card img {
      width: 96px;
      height: 96px;
      object-fit: contain;
      filter: drop-shadow(0 6px 8px rgba(0,0,0,0.08));
    }

    .feature-label {
      min-width: 208px;
      min-height: 82px;
      padding: 12px 16px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.78);
      display: grid;
      place-items: center;
      text-align: center;
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.05);
    }

    .feature-label strong {
      font-size: clamp(1.6rem, 2vw, 2.1rem);
      line-height: 1.1;
      font-weight: 800;
    }

    .feature-label.small strong {
      font-size: clamp(1.15rem, 1.55vw, 1.5rem);
    }

    .bottom-row {
      display: flex;
      justify-content: flex-end;
      gap: 18px;
      margin-top: 24px;
      flex-wrap: wrap;
    }

    .mini-btn,
    .cta-btn {
      background: rgba(255, 255, 255, 0.82);
      border-radius: 12px;
      min-width: 160px;
      padding: 14px 22px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 1.15rem;
      font-weight: 700;
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.05);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .mini-btn .emoji {
      font-size: 1.6rem;
      line-height: 1;
    }

    .cta-btn {
      background: #ffffff;
    }

    @media (max-width: 1100px) {
      .hero {
        grid-template-columns: 1fr;
      }

      .hero-visual {
        justify-content: center;
      }

      .hero-actions {
        min-height: auto;
        padding-left: 0;
        align-items: center;
      }

      .feature-row {
        grid-template-columns: repeat(2, minmax(180px, 220px));
        justify-content: center;
      }

      .bottom-row {
        justify-content: center;
      }
    }

    @media (max-width: 760px) {
      .page {
        padding: 20px 16px 32px;
      }

      .topbar {
        flex-direction: column;
        align-items: stretch;
        margin-bottom: 28px;
      }

      .nav-actions {
        justify-content: flex-start;
      }

      .hero-title {
        margin-bottom: 26px;
      }

      .doctor-wrap {
        transform: scale(0.88);
      }

      .feature-row {
        grid-template-columns: 1fr;
        gap: 24px;
      }

      .feature-label,
      .mini-btn,
      .cta-btn,
      .nav-btn {
        min-width: unset;
        width: 100%;
      }

      .bottom-row {
        width: 100%;
      }

      .bottom-row a {
        flex: 1 1 100%;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <header class="topbar">
      <div class="brand">
        <div class="brand-logo" aria-hidden="true"></div>
        <div class="brand-text">
          <h1>TeenHealth Analytics System</h1>
          <p>Hệ thống hỗ trợ phân tích sức khỏe học đường</p>
        </div>
      </div>

      <nav class="nav-actions">
        <a class="nav-btn" href="#gioi-thieu">Giới thiệu</a>
        <a class="nav-btn" href="#dang-nhap">Đăng nhập</a>
      </nav>
    </header>

    <section class="hero">
      <div>
        <h2 class="hero-title">Hành trình khỏe mạnh – luôn có tụi mình bên bạn!</h2>

        <div class="hero-visual">
          <div class="doctor-wrap">
            <span class="bubble one"></span>
            <span class="bubble two"></span>
            <span class="bubble three"></span>
            <span class="bubble four"></span>

            <div class="phone-shape"></div>
            <div class="home-btn"></div>

            <div class="icon-circle a">💉</div>
            <div class="icon-circle b">💊</div>
            <div class="icon-circle c">➕</div>
            <div class="icon-circle d">❤</div>

            <div class="doctor">
              <div class="hair"></div>
              <div class="head"></div>
              <div class="body"></div>
              <div class="shirt"></div>
              <div class="arm-left"></div>
              <div class="arm-right"></div>
              <div class="hand"></div>
              <div class="clipboard"></div>
              <div class="stethoscope"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="hero-actions">
        <div class="feature-row">
          <a class="feature-card" href="#kien-thuc">
            <img src="https://cdn-icons-png.flaticon.com/512/3135/3135755.png" alt="Kiến thức" />
            <div class="feature-label">
              <strong>Kiến thức</strong>
            </div>
          </a>

          <a class="feature-card" href="#phan-tich">
            <img src="https://cdn-icons-png.flaticon.com/512/2920/2920277.png" alt="Phân tích sức khỏe" />
            <div class="feature-label small">
              <strong>Phân tích<br>sức khỏe</strong>
            </div>
          </a>
        </div>

        <div class="bottom-row">
          <a class="mini-btn" href="#huong-dan"><span class="emoji">❓</span>Hướng dẫn</a>
          <a class="cta-btn" href="#khao-sat">Khảo sát</a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
